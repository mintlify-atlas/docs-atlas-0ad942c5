  "keyFeatures": [
    "Course catalog with search and filtering",
    "Stripe payment integration for course purchases",
    "AI-powered chatbot for learning support",
    "Personalized learning roadmap generation",
    "Auto-generated quizzes with explanations",
    "Progress tracking and analytics dashboard",
    "Community groups with discussion posts",
    "Multi-role system (students, educators, admins)",
    "Course builder with rich content editor",
    "Real-time enrollment and revenue stats"
  ],
  "publicApiSurface": [
    "GET /api/course/all - List all published courses",
    "GET /api/course/:id - Get course details by ID",
    "POST /api/user/purchase - Purchase a course",
    "POST /api/user/update-course-progress - Update learning progress",
    "GET /api/user/enrolled-courses - Get user's enrolled courses",
    "POST /api/user/ai-chat - Chat with AI assistant",
    "POST /api/user/generate-personal-roadmap - Generate learning roadmap",
    "POST /api/quiz/generate - Generate chapter quiz",
    "GET /api/community/groups - List community groups",
    "POST /api/community/posts - Create discussion post",
    "POST /api/educator/add-course - Create new course (educators)",
    "GET /api/educator/dashboard - Get educator stats",
    "GET /api/admin/stats - Get platform-wide statistics (admins)",
    "PATCH /api/admin/educator-applications/:id/approve - Approve educator application",
    "POST /clerk - Clerk user sync webhook",
    "POST /stripe - Stripe payment webhook"
  ]
